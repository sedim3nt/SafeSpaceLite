# ── Hardhat / Contract Deployment ──────────────────────
# Private key of the deployer wallet (without 0x prefix is fine, Hardhat handles both)
DEPLOYER_PRIVATE_KEY=

# RPC URLs (defaults to public endpoints if not set)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ── Frontend (Vite) ──────────────────────────────────
# These must start with VITE_ to be available in the browser

# Privy App ID (free at https://dashboard.privy.io)
VITE_PRIVY_APP_ID=

# Deployed contract address (set after running: npx hardhat run scripts/deploy.ts --network base-sepolia)
VITE_CONTRACT_ADDRESS=
