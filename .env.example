# SafeSpace Lite — Environment Variables
# Copy this to .env.local and fill in values

# Supabase (get from supabase.com > Project Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# USPS Addresses API (register at developer.usps.com)
# Used for address validation and standardization
VITE_USPS_API_KEY=your-usps-api-key

# Stripe (get from dashboard.stripe.com)
# Used for $10 landlord rebuttal payments
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
